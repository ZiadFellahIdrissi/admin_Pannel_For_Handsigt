{
  "name": "handsight-admin-panel",
  "version": "1.0.0",
  "description": "Admin panel for Handsight Solutions - consultants, clients, and month-submission approvals",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "hash-password": "node scripts/hash-password.js"
  },
  "dependencies": {
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "mysql2": "^3.11.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
