<%- include('../partials/head', { title: 'Consultants' }) %>
<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>
  <div class="flex-1 flex flex-col min-w-0">
    <%- include('../partials/topbar', { title: 'Consultants' }) %>
    <%- include('../partials/flash') %>
    <div class="max-w-6xl mx-auto px-3 sm:px-4 py-6 sm:py-8 w-full">
  <div class="flex items-center justify-between flex-wrap gap-3 mb-4 sm:mb-6">
    <h1 class="text-lg sm:text-xl font-bold flex items-center gap-3">
      <div class="icon-circle-accent"><i class="fa-solid fa-users"></i></div>
      Consultants
    </h1>
    <a href="/consultants/new" class="btn-primary">
      <i class="fa-solid fa-plus"></i>New Consultant
    </a>
  </div>

  <div class="flex items-center gap-2 mb-4 text-sm">
    <a href="/consultants?active=1" class="btn-secondary <%= activeFilter === '1' ? '!border-brand-accent !text-brand-accent' : '' %>">Active</a>
    <a href="/consultants?active=0" class="btn-secondary <%= activeFilter === '0' ? '!border-brand-accent !text-brand-accent' : '' %>">Inactive</a>
    <a href="/consultants?active=all" class="btn-secondary <%= activeFilter === 'all' ? '!border-brand-accent !text-brand-accent' : '' %>">All</a>
  </div>

  <% if (consultants.length === 0) { %>
    <div class="card p-8 text-center">
      <i class="fa-regular fa-folder-open text-2xl text-brand-gray2 mb-2"></i>
      <p class="text-sm text-brand-gray2">No consultants found.</p>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% consultants.forEach(function(c) { %>
        <div class="card-interactive p-4 flex items-center justify-between gap-3 flex-wrap">
          <a href="/consultants/<%= c.id %>" class="flex items-center gap-3 min-w-0 flex-1">
            <div class="icon-circle-slate font-bold text-sm"><%= (c.first_name.charAt(0) + c.last_name.charAt(0)).toUpperCase() %></div>
            <div class="min-w-0">
              <div class="font-semibold truncate"><%= c.first_name %> <%= c.last_name %></div>
              <div class="text-xs text-brand-gray2 mt-0.5"><%= c.username %> &middot; <%= c.email %></div>
            </div>
          </a>
          <div class="flex items-center gap-2 shrink-0">
            <span class="text-sm font-semibold"><%= formatCurrency(c.daily_rate) %></span>
            <span class="<%= c.active ? 'badge-approved' : 'badge-draft' %>"><%= c.active ? 'Active' : 'Inactive' %></span>
            <a href="/consultants/<%= c.id %>/edit" class="btn-secondary text-sm"><i class="fa-solid fa-pen"></i></a>
            <form action="/consultants/<%= c.id %>/toggle-active" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="returnTo" value="/consultants?active=<%= activeFilter %>">
              <button type="submit" class="btn-secondary text-sm"><%= c.active ? 'Deactivate' : 'Activate' %></button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
