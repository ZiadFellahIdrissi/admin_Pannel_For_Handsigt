<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %>Handsight Admin Panel</title>
  <link rel="icon" type="image/png" href="/images/logo.png">
  <!-- Blocking (no defer/async) and placed before the stylesheet on purpose:
       sets data-theme before first paint so a dark-mode visitor never sees
       a flash of the light theme while the page loads. -->
  <script src="/js/theme-init.js?v=<%= assetVersion %>"></script>
  <link rel="stylesheet" href="/css/output.css?v=<%= assetVersion %>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
        referrerpolicy="no-referrer">
</head>
<body class="min-h-screen bg-brand-light text-brand-text">
