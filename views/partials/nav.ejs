<% if (currentUser) { %>
<nav class="bg-brand text-white shadow-lg shadow-black/20 sticky top-0 z-10">
  <div class="max-w-6xl mx-auto px-3 sm:px-4 py-2.5 flex items-center justify-between flex-wrap gap-2">
    <div class="flex items-center gap-1 sm:gap-3 flex-wrap">
      <span class="font-bold tracking-tight flex items-center gap-2 shrink-0 pr-1 sm:pr-2 sm:border-r sm:border-brand-borderDark">
        <img src="/images/logo.png" alt="Handsight Solutions" class="h-7 w-7 rounded-full ring-2 ring-white/10">
        <span class="hidden sm:inline text-sm">Admin Panel</span>
      </span>
      <a href="/consultants" class="text-sm px-2.5 sm:px-3 py-1.5 rounded-lg transition-colors <%= currentPath.startsWith('/consultants') ? 'bg-white/10 text-white font-semibold' : 'text-brand-gray hover:text-white hover:bg-white/5' %>">
        <i class="fa-solid fa-users sm:mr-1.5"></i><span class="hidden sm:inline">Consultants</span>
      </a>
      <a href="/clients" class="text-sm px-2.5 sm:px-3 py-1.5 rounded-lg transition-colors <%= currentPath.startsWith('/clients') ? 'bg-white/10 text-white font-semibold' : 'text-brand-gray hover:text-white hover:bg-white/5' %>">
        <i class="fa-solid fa-building sm:mr-1.5"></i><span class="hidden sm:inline">Clients</span>
      </a>
      <a href="/approvals" class="text-sm px-2.5 sm:px-3 py-1.5 rounded-lg transition-colors <%= currentPath.startsWith('/approvals') ? 'bg-white/10 text-white font-semibold' : 'text-brand-gray hover:text-white hover:bg-white/5' %>">
        <i class="fa-solid fa-clipboard-check sm:mr-1.5"></i><span class="hidden sm:inline">Approval Queue</span>
      </a>
      <a href="/history" class="text-sm px-2.5 sm:px-3 py-1.5 rounded-lg transition-colors <%= currentPath.startsWith('/history') ? 'bg-white/10 text-white font-semibold' : 'text-brand-gray hover:text-white hover:bg-white/5' %>">
        <i class="fa-solid fa-clock-rotate-left sm:mr-1.5"></i><span class="hidden sm:inline">History</span>
      </a>
      <a href="/login-attempts" class="text-sm px-2.5 sm:px-3 py-1.5 rounded-lg transition-colors <%= currentPath.startsWith('/login-attempts') ? 'bg-white/10 text-white font-semibold' : 'text-brand-gray hover:text-white hover:bg-white/5' %>">
        <i class="fa-solid fa-shield-halved sm:mr-1.5"></i><span class="hidden sm:inline">Login Attempts</span>
      </a>
    </div>
    <div class="flex items-center gap-2 sm:gap-3 text-sm">
      <button type="button" id="theme-toggle-btn" class="theme-toggle" aria-label="Toggle theme">
        <i id="theme-toggle-icon" class="fa-solid fa-moon"></i>
      </button>
      <form action="/logout" method="POST" class="inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="text-brand-gray hover:text-white transition-colors">
          <i class="fa-solid fa-right-from-bracket sm:mr-1"></i><span class="hidden sm:inline">Logout</span>
        </button>
      </form>
    </div>
  </div>
</nav>
<script src="/js/theme-toggle.js?v=<%= assetVersion %>" defer></script>
<% } %>
