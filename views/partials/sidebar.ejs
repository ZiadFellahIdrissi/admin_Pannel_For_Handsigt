<% if (currentUser) {
  var isConsultants = currentPath === '/consultants' || currentPath.indexOf('/consultants/') === 0;
  var isClients = currentPath === '/clients' || currentPath.indexOf('/clients/') === 0;
  var isApprovals = currentPath.indexOf('/approvals') === 0;
  var isHistory = currentPath.indexOf('/history') === 0;
  var isLoginAttempts = currentPath.indexOf('/login-attempts') === 0;
  var isDashboard = currentPath === '/';
%>
<div id="sidebar-backdrop" class="sidebar-backdrop"></div>
<aside id="sidebar-panel" class="sidebar-panel">
  <div class="h-16 px-4 flex items-center gap-2.5 border-b border-brand-borderLight shrink-0">
    <img src="/images/logo.png" alt="Handsight Solutions" class="h-8 w-8 rounded-full ring-2 ring-brand-accentDim">
    <span class="font-bold text-sm">Admin Panel</span>
  </div>

  <nav class="p-3">
    <a href="/" class="<%= isDashboard ? 'sidebar-link-active' : 'sidebar-link' %>">
      <i class="fa-solid fa-gauge w-4 text-center"></i>Dashboard
    </a>

    <div class="sidebar-section-title">Consultants Management</div>
    <div class="space-y-1">
      <a href="/consultants" class="<%= isConsultants ? 'sidebar-link-active' : 'sidebar-link' %>">
        <i class="fa-solid fa-users w-4 text-center"></i>Consultants
      </a>
      <a href="/clients" class="<%= isClients ? 'sidebar-link-active' : 'sidebar-link' %>">
        <i class="fa-solid fa-building w-4 text-center"></i>Clients
      </a>

      <details <%= (isApprovals || isHistory) ? 'open' : '' %>>
        <summary class="sidebar-sublabel-toggle list-none">
          <i class="fa-solid fa-file-invoice w-4 text-center"></i>CRA (Timesheet)
          <i class="fa-solid fa-chevron-down sidebar-sublabel-chevron"></i>
        </summary>
        <div class="space-y-1 mt-1 pl-4">
          <a href="/approvals" class="<%= isApprovals ? 'sidebar-link-active' : 'sidebar-link' %>">
            <i class="fa-solid fa-clipboard-check w-4 text-center"></i>Approval Queue
            <% if (notificationCount > 0) { %><span class="badge-pending !py-0.5 !px-2 ml-auto"><%= notificationCount %></span><% } %>
          </a>
          <a href="/history" class="<%= isHistory ? 'sidebar-link-active' : 'sidebar-link' %>">
            <i class="fa-solid fa-clock-rotate-left w-4 text-center"></i>History
          </a>
        </div>
      </details>
    </div>

    <div class="sidebar-section-title">Billing</div>
    <div class="sidebar-link-disabled">
      <i class="fa-solid fa-file-invoice-dollar w-4 text-center"></i>Invoicing
      <span class="badge-draft !py-0.5 !px-2 ml-auto">Soon</span>
    </div>

    <div class="sidebar-section-title">Treasury</div>
    <div class="sidebar-link-disabled">
      <i class="fa-solid fa-building-columns w-4 text-center"></i>Cash &amp; Accounts
      <span class="badge-draft !py-0.5 !px-2 ml-auto">Soon</span>
    </div>

    <div class="sidebar-section-title">Earnings Dashboard</div>
    <div class="sidebar-link-disabled">
      <i class="fa-solid fa-chart-line w-4 text-center"></i>Earnings &amp; Spending
      <span class="badge-draft !py-0.5 !px-2 ml-auto">Soon</span>
    </div>

    <div class="sidebar-section-title">Security</div>
    <div class="space-y-1">
      <a href="/login-attempts" class="<%= isLoginAttempts ? 'sidebar-link-active' : 'sidebar-link' %>">
        <i class="fa-solid fa-shield-halved w-4 text-center"></i>Login Attempts
      </a>
    </div>
  </nav>
</aside>
<% } %>
