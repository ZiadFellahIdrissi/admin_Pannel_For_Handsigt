<% if (currentUser) { %>
<header class="bg-brand text-white shadow-lg shadow-black/20 sticky top-0 z-10">
  <div class="px-3 sm:px-4 py-2.5 flex items-center justify-between gap-3">
    <div class="flex items-center gap-3 min-w-0">
      <button type="button" id="sidebar-toggle-btn" class="theme-toggle lg:hidden" aria-label="Toggle menu">
        <i class="fa-solid fa-bars"></i>
      </button>
      <h1 class="text-sm font-semibold truncate"><%= typeof title !== 'undefined' ? title : '' %></h1>
    </div>
    <div class="flex items-center gap-1.5 sm:gap-2.5 text-sm shrink-0">
      <details class="relative">
        <summary class="theme-toggle list-none cursor-pointer relative" aria-label="Notifications">
          <i class="fa-solid fa-bell"></i>
          <% if (notificationCount > 0) { %>
            <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] leading-none rounded-full min-w-[16px] h-4 flex items-center justify-center px-1"><%= notificationCount %></span>
          <% } %>
        </summary>
        <div class="absolute right-0 mt-2 w-72 sm:w-80 card p-2 z-20 shadow-xl text-brand-text">
          <div class="px-2 py-1.5 text-xs font-bold uppercase tracking-wide text-brand-gray2">Pending Submissions</div>
          <% if (notificationPending.length === 0) { %>
            <p class="px-2 py-3 text-sm text-brand-gray2">Nothing waiting on you right now.</p>
          <% } else { %>
            <div class="max-h-72 overflow-y-auto">
              <% notificationPending.slice(-6).reverse().forEach(function(p) { %>
                <a href="/approvals" class="notif-item">
                  <div class="font-medium"><%= p.consultant_name %> &middot; <%= p.client_name %></div>
                  <div class="text-xs text-brand-gray2"><%= monthLabel(p.month) %> &middot; submitted <%= p.submitted_at %></div>
                </a>
              <% }); %>
            </div>
          <% } %>
          <a href="/approvals" class="block text-center text-xs font-semibold text-brand-accent px-2 py-2 border-t border-brand-borderLight mt-1">View all in Approval Queue</a>
        </div>
      </details>
      <button type="button" id="theme-toggle-btn" class="theme-toggle" aria-label="Toggle theme">
        <i id="theme-toggle-icon" class="fa-solid fa-moon"></i>
      </button>
      <form action="/logout" method="POST" class="inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="text-brand-gray hover:text-white transition-colors">
          <i class="fa-solid fa-right-from-bracket sm:mr-1"></i><span class="hidden sm:inline">Logout</span>
        </button>
      </form>
    </div>
  </div>
</header>
<script src="/js/theme-toggle.js?v=<%= assetVersion %>" defer></script>
<script src="/js/sidebar-toggle.js?v=<%= assetVersion %>" defer></script>
<% } %>
